# Environment Variables for TikTok Viral Clothing Bot
# Copy this file to .env and fill in your credentials

# ========================================
# TikTok Official API (Recommended)
# ========================================
# Get credentials from: https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here

# ========================================
# Apify API (Easiest method)
# ========================================
# Get token from: https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_token_here

# ========================================
# RapidAPI (Alternative)
# ========================================
# Get from: https://rapidapi.com/
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=tiktok-api-host.rapidapi.com

# ========================================
# Proxy Configuration (For unsafe scraping)
# ========================================
# Use residential proxies from providers like:
# - Bright Data: https://brightdata.com
# - Smartproxy: https://smartproxy.com
# - Oxylabs: https://oxylabs.io

PROXY_ENABLED=false
PROXY_URL=http://your-proxy-server:port
PROXY_USERNAME=your_proxy_username
PROXY_PASSWORD=your_proxy_password

# ========================================
# Rate Limiting
# ========================================
MAX_REQUESTS_PER_MINUTE=10
DELAY_BETWEEN_REQUESTS=6

# ========================================
# Data Source Selection
# ========================================
# Choose which scraper to use:
# - official: Official TikTok API (safest, requires approval)
# - apify: Apify cloud service (easy, paid)
# - csv: Manual CSV import (safest, manual work)
# - demo: Demo mode with sample data (for testing)

DATA_SOURCE=demo
